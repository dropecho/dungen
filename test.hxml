-cp src
-cp test

# Library dependencies plus the test stack. `dropecho.testing` auto-discovers
# every `*Tests.hx` class on the classpath and injects the `--main` entry point
# itself, so none is set here.
-lib seedyrng
-lib dropecho.ds
-lib dropecho.interop
-lib dropecho.testing
-lib utest

-D analyzer-optimize

# Compile the whole library so the suite links every module, not just what the
# tests reach.
--macro include('', true, null, ['src'])

# Code coverage is a separate build — see `coverage.hxml` / `npm run coverage`.
# The `dropecho.testing` runner here never calls `Sys.exit`, which the
# `instrument` lcov reporter needs in order to flush, so coverage can't be
# produced from this hxml.

# Narrow a run to a single test while debugging, e.g.:
# -D UTEST_PATTERN=test_distance_fill

--each

# The suite runs on every runnable target below. These mirror the program
# targets in targets/ — cs and docs are skipped (not runnable test programs) and
# js-esm shares the js runtime, so neither adds test coverage.

# JS (Node)
--next
-lib hxnodejs
-D js-es=6
-js artifacts/js_test.cjs

# C# — uncomment where mono is registered to exec the built .exe directly.
# --next
# -D net-ver=40
# -cs artifacts/cs_test

# Python
# --next
# -python artifacts/python_test
